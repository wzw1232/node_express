# -----------------------------------------------------------------
# ESLint 忽略清单
# 匹配规则同 .gitignore，以项目根目录为基准
# -----------------------------------------------------------------

# 依赖目录——不是本项目代码，不检查
node_modules/

# 构建产物
dist/
build/

# 环境变量文件（可能含敏感信息，避免被 lint 时误读）
.env
.env.local
.env.*.local

# 日志
*.log
npm-debug.log*

# IDE 与编辑器
.vscode/
.idea/

# 临时文件
*.tmp
*.temp
coverage/
