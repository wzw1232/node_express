# ===========================================================================
# 应用服务器
# ===========================================================================
PORT=3000

# ===========================================================================
# JWT 认证
# ===========================================================================
# 签名密钥，生产环境务必更改为高强度随机字符串
JWT_SECRET=change-this-secret
# 令牌有效期，支持格式：7d / 24h / 60m / 3600s
JWT_EXPIRES_IN=7d

# ===========================================================================
# MySQL 数据库连接（必填项，缺一不可）
# 详细参数说明参见 src/db/config.js
# ===========================================================================
DB_HOST=127.0.0.1
# DB_PORT=3306
DB_PORT=9527
DB_USER=root
DB_PASSWORD=1232
DB_NAME=demo

# ===========================================================================
# 数据库连接池调优（可选，以下为默认值，可按需取消注释覆盖）
# ===========================================================================
# DB_ACQUIRE_TIMEOUT=10000    # 获取连接超时 (ms)，默认 10s
# DB_CONNECT_TIMEOUT=10000    # 建立连接超时 (ms)，默认 10s
# DB_IDLE_TIMEOUT=300000      # 空闲连接回收时间 (ms)，默认 5min
# DB_TIMEZONE=+08:00          # 时区偏移
